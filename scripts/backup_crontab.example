#!/bin/bash
# 定时备份数据库的 crontab 配置示例
# 用法：将此文件内容添加到 crontab
#       crontab /home/abc/Project-Material-Management-System/scripts/backup_crontab.example

# 环境变量设置
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
MAILTO=""

# 每天凌晨 2 点自动备份数据库（保留 30 天）
0 2 * * * cd /home/abc/Project-Material-Management-System && bash scripts/backup_db.sh 30 >> /home/abc/Project-Material-Management-System/logs/backup.log 2>&1

# 每周日早上 3 点备份（保留 90 天，用于长期备份）
0 3 * * 0 cd /home/abc/Project-Material-Management-System && bash scripts/backup_db.sh 90 >> /home/abc/Project-Material-Management-System/logs/backup_weekly.log 2>&1
