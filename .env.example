# Django 环境变量配置
# 复制为 .env 并修改实际值

# 安全密钥（必改！生产环境必须更换为随机密钥）
# 生成新密钥: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=请替换为随机生成的密钥

# 调试模式（生产环境必须设为 False）
DEBUG=True

# 允许的主机（逗号分隔，生产环境必须指定具体域名/IP）
ALLOWED_HOSTS=0.0.0.0

# 数据库配置（PostgreSQL）
DB_NAME=material_system
DB_USER=postgres
DB_PASSWORD=请设置数据库密码
DB_HOST=127.0.0.1
DB_PORT=5432

# 时区和语言
TIME_ZONE=Asia/Shanghai
LANGUAGE_CODE=zh-hans

# 登录限流配置（已移至系统设置界面，此处仅作为初始值参考）
# 可在系统管理 -> 系统设置 -> 登录限流配置 中修改
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_LOCKOUT_SECONDS=300

# Sentry 错误追踪（生产环境）
# 在 https://sentry.io 创建项目获取 DSN
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_TRACES_SAMPLE_RATE=0.1  # 性能追踪采样率（0.0-1.0）
# SENTRY_PROFILES_SAMPLE_RATE=0.1  # 性能分析采样率（0.0-1.0）
# SENTRY_ENVIRONMENT=production  # 环境标识
# APP_VERSION=1.8.0  # 应用版本号

# 管理员账号（用于 createsuperuser 自动化）
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=请设置强密码
